# ============================================================
# .env — Tukar nama fail ini kepada .env sebelum run
# JANGAN commit .env ke Git (sudah dalam .gitignore)
# ============================================================

# Server
NODE_ENV=production
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sistem_tempahan
DB_USER=tempahan_user
DB_PASSWORD=PasswordKuatAndaSini

# Sesi & JWT (jana rentetan rawak >32 char)
SESSION_SECRET=tukar_ke_rentetan_rawak_panjang_sekurang_kurangnya_32_char
JWT_SECRET=tukar_ke_rentetan_rawak_lain_yang_panjang_sekurang_kurangnya_32_char

# Admin default (digunakan jika setup script dijalankan)
ADMIN_DEFAULT_USER=admin
ADMIN_DEFAULT_PASS=admin123

# Timezone
TZ=Asia/Kuala_Lumpur

# Frontend public URL (untuk CORS)
PUBLIC_URL=https://tempahan.byzaifuan.com
